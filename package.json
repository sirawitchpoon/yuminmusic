{
  "name": "yuminmusic",
  "version": "0.1.0",
  "description": "Discord music bot for yuminyui — cute Thai VTuber music companion",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "deploy:commands": "tsx src/scripts/deployCommands.ts"
  },
  "dependencies": {
    "@discord-player/extractor": "^7.2.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "discord-player": "^7.2.0",
    "discord-player-youtubei": "^2.0.0",
    "discord.js": "^14.26.0",
    "dotenv": "^17.0.0",
    "ffmpeg-static": "^5.3.0",
    "mediaplex": "^1.0.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "youtube-dl-exec": "^3.1.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.9.0"
  }
}
