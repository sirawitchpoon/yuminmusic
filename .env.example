# Discord bot credentials (จาก https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Guild ที่ bot จะประจำการ (ใช้ลง slash command แบบ instant)
GUILD_ID=

# Role IDs
# ADMIN_ROLE_ID = เต็มอำนาจ (stop, disconnect, force skip, clear queue)
# DJ_ROLE_ID = ควบคุม playback ได้ (pause/skip/queue) — optional, ปล่อยว่างได้
ADMIN_ROLE_ID=
DJ_ROLE_ID=

# Skip vote: สัดส่วนคนใน voice ที่ต้องโหวต (0.5 = 50%)
SKIP_VOTE_RATIO=0.5

# Disconnect bot หลัง idle กี่มิลลิวินาที (default 5 นาที)
IDLE_DISCONNECT_MS=300000

# Default volume 0-100
DEFAULT_VOLUME=50

# Path ของรูป banner/gif ของยุย (วางไฟล์จริงใน assets/)
PANEL_BANNER_PATH=./assets/banner.png
PANEL_GIF_PATH=./assets/yui-idle.gif

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
